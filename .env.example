# Path to the SQLite database file. Defaults to ./data/worksheet.db if unset.
# DATABASE_PATH=./data/worksheet.db

# Required for the AI bulk-import feature (/create/ai). Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional, defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Admin panel password (cookie angmatura_admin). Pick something you don't use anywhere else.
ADMIN_PASSWORD=change-me
