{
	"name": "angmatura",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"start": "node --env-file-if-exists=.env build/index.js",
		"clear-explanations": "node scripts/clear-explanations.mjs",
		"test": "vitest run"
	},
	"devDependencies": {
      "@sveltejs/kit": "^2.70.1",
      "@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/better-sqlite3": "^7.6.13",
      "svelte": "^5.56.6",
      "svelte-check": "^4.7.3",
		"typescript": "^6.0.3",
      "vite": "^8.1.5",
      "vitest": "^3.2.7"
	},
	"dependencies": {
      "@google/genai": "^2.12.0",
      "@lucide/svelte": "^1.25.0",
		"@sveltejs/adapter-node": "^5.5.7",
		"better-sqlite3": "^12.11.1"
	}
}
